# Copy this file to .env and fill values

# Base API host (update if your account uses a different host)
WQ_BASE_URL=https://api.worldquantbrain.com

# Optional app-level authentication (recommended for hosted deployments)
APP_AUTH_ENABLED=0
APP_AUTH_USERNAME=
APP_AUTH_PASSWORD=

# Auth mode A: token (preferred if available)
# WQ_API_TOKEN=

# Auth mode B: email/password
# WQ_USERNAME=your_username_if_required
WQ_EMAIL=
WQ_PASSWORD=
WQ_AUTH_PATH=/authentication
WQ_AUTH_CHECK_PATH=/authentication
WQ_STRICT_AUTH_CHECK=0

# Safe diagnostics (prints masked login info and config presence only)
WQ_DEBUG=0

# Usually keep this OFF; some deployments return non-API tokens in auth payload.
WQ_USE_AUTH_RESPONSE_TOKEN=0

# Simulation endpoints (adjust if your tenant differs)
WQ_SIMULATIONS_PATH=/simulations
WQ_SIMULATION_RESULT_TEMPLATE=/simulations/{id}
WQ_ALPHA_RESULT_TEMPLATE=/alphas/{id}

# Retry controls (helps with temporary API rate limiting)
WQ_AUTH_RETRIES=5
WQ_SUBMIT_RETRIES=3

# Expression to test
WQ_EXPRESSION=reverse(returns)

# Brain simulation settings
WQ_INSTRUMENT_TYPE=EQUITY
WQ_REGION=USA
WQ_UNIVERSE=TOP3000
WQ_DELAY=1
WQ_DECAY=0
WQ_NEUTRALIZATION=INDUSTRY
WQ_TRUNCATION=0.01
WQ_VISUALIZATION=0
WQ_PASTEURIZATION=ON
WQ_UNIT_HANDLING=VERIFY
WQ_NAN_HANDLING=OFF
WQ_LANGUAGE=FASTEXPR

# Polling
WQ_POLL_ATTEMPTS=120
WQ_POLL_INTERVAL_SEC=2
